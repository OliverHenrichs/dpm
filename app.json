{
  "expo": {
    "name": "DancePatternMapper",
    "slug": "DancePatternMapper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "dancepatternmapper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundImage": "./assets/images/favicon.png",
        "monochromeImage": "./assets/images/favicon.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.teholi.DancePatternMapper"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af32961a-d382-4766-86aa-3b3ccafbaa2d"
      },
      "firebase": {
        "apiKey": "AIzaSyCm9dnv0PbmqQ-BcefBwY2T8aMCfZ4nyUI",
        "authDomain": "dancepatternmapper.firebaseapp.com",
        "projectId": "dancepatternmapper",
        "storageBucket": "dancepatternmapper.firebasestorage.app",
        "messagingSenderId": "403802543234",
        "appId": "1:403802543234:web:3050c05e82eb0f832d909b",
        "measurementId": "G-T7RWDJLG3E"
      },
      "firebaseAppToken": "DPM-dance-pattern-mapper"
    }
  }
}
